# Required for local runs of `npm run check`.
# Copy this file to .env and fill in real values. The .env file is gitignored.

# From https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# From https://resend.com/api-keys (added in Checkpoint 5)
RESEND_API_KEY=

# Where alert emails are sent (added in Checkpoint 5)
ALERT_EMAIL=
